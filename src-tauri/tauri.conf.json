{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Bexo Studio",
  "version": "0.1.3",
  "identifier": "studio.bexo.desktop",
  "build": {
    "beforeDevCommand": "npm run web:dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run web:build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Bexo Studio",
        "width": 1560,
        "height": 980,
        "minWidth": 1280,
        "minHeight": 760,
        "resizable": true,
        "decorations": true,
        "fullscreen": false,
        "visible": true
      },
      {
        "label": "screenshot_overlay",
        "title": "Bexo Studio Screenshot",
        "url": "index.html?overlay=screenshot",
        "x": 0,
        "y": 0,
        "width": 1280,
        "height": 720,
        "minWidth": 640,
        "minHeight": 360,
        "resizable": false,
        "decorations": false,
        "transparent": false,
        "fullscreen": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "visible": false,
        "focus": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
