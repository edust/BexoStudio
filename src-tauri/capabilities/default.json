{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main Bexo Studio window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "autostart:default",
    "dialog:default",
    "global-shortcut:default",
    "log:default",
    "notification:default",
    "opener:default",
    "opener:allow-open-path",
    "store:default",
    "window-state:default"
  ]
}
